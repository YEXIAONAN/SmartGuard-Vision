APP_NAME=智感护航后端平台中枢
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
RELOAD=true

# 开发环境可直接使用默认 sqlite，本项目接入 MySQL 时建议取消下一行注释。
DATABASE_URL=mysql+pymysql://root:123456@127.0.0.1:3306/smartguard_vision?charset=utf8mb4

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=smartguard_vision

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173
